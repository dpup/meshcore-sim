{
  "name": "@dpup/meshcore-sim",
  "version": "0.1.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "A deterministic, behavioral MeshCore network simulator for testing meshcore.js / @dpup/meshcore-ts apps without radios. The grown-up form of a hand-written connection stub.",
  "type": "module",
  "license": "MIT",
  "author": "Dan Pupius",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dpup/meshcore-sim.git"
  },
  "homepage": "https://github.com/dpup/meshcore-sim#readme",
  "bugs": "https://github.com/dpup/meshcore-sim/issues",
  "keywords": [
    "meshcore",
    "mesh",
    "lora",
    "radio",
    "simulator",
    "testing",
    "typescript"
  ],
  "engines": {
    "node": ">=18",
    "bun": ">=1.2.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs": "typedoc && node scripts/postdocs.mjs",
    "docs:check": "typedoc && node scripts/postdocs.mjs && node scripts/docs-check.mjs",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "@dpup/meshcore-ts": "^0.1.1",
    "@liamcottle/meshcore.js": "^1.13.0"
  },
  "devDependencies": {
    "@dpup/meshcore-ts": "^0.1.1",
    "@liamcottle/meshcore.js": "^1.13.0",
    "@types/node": "^25.9.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
